---
import { useTranslations } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
---

<section class="bg-midnight-900 text-surface py-8 md:py-10 border-t border-midnight-700">
  <div class="container-wide">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 md:gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-saffron-300 font-semibold">
          {t.countdown.headline}
        </p>
        <p class="mt-1.5 font-serif text-xl md:text-2xl">{t.countdown.deadline}</p>
      </div>

      <div
        class="flex gap-4 sm:gap-5"
        data-countdown
        data-target={config.deadlines.submission}
        data-label-days={t.countdown.days}
        data-label-hours={t.countdown.hours}
        data-label-minutes={t.countdown.minutes}
        data-label-seconds={t.countdown.seconds}
        data-label-closed={t.countdown.closed}
      >
        {[
          { unit: "days", label: t.countdown.days },
          { unit: "hours", label: t.countdown.hours },
          { unit: "minutes", label: t.countdown.minutes },
          { unit: "seconds", label: t.countdown.seconds },
        ].map(({ unit, label }) => (
          <div class="text-center min-w-[52px] md:min-w-[64px]">
            <div class="font-serif text-2xl md:text-3xl lg:text-4xl font-semibold text-saffron-300 tabular-nums" data-unit={unit}>--</div>
            <div class="text-[0.6rem] uppercase tracking-widest text-surface/60 mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-countdown]");
  if (root) {
    const target = new Date(root.dataset.target ?? "").getTime();
    const labelClosed = root.dataset.labelClosed ?? "";
    const units = {
      days: root.querySelector<HTMLElement>('[data-unit="days"]'),
      hours: root.querySelector<HTMLElement>('[data-unit="hours"]'),
      minutes: root.querySelector<HTMLElement>('[data-unit="minutes"]'),
      seconds: root.querySelector<HTMLElement>('[data-unit="seconds"]'),
    };
    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        root.innerHTML = `<p class="font-serif text-xl text-saffron-300">${labelClosed}</p>`;
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);
      if (units.days) units.days.textContent = String(days);
      if (units.hours) units.hours.textContent = String(hours).padStart(2, "0");
      if (units.minutes) units.minutes.textContent = String(minutes).padStart(2, "0");
      if (units.seconds) units.seconds.textContent = String(seconds).padStart(2, "0");
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
