---
import { useTranslations } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const items = t.testimonials.items;
---

<section class="py-12 md:py-20 lg:py-24 border-t border-midnight-100">
  <div class="container-wide">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">
      {t.testimonials.kicker}
    </p>
    <h2 class="font-serif text-3xl md:text-4xl font-semibold text-midnight-800 leading-tight mb-10 md:mb-14">
      {t.testimonials.title}
    </h2>
  </div>

  <div class="t-viewport">
    <div class="t-track">
      {[...items, ...items].map((item) => (
        <blockquote class="t-card">
          <p class="t-quote">&ldquo;{item.quote}&rdquo;</p>
          <footer class="t-footer">
            <p class="t-name">{item.name}</p>
            <p class="t-role">{item.role}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .t-viewport {
    overflow: hidden;
    direction: ltr;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 7%, black 93%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, black 7%, black 93%, transparent 100%);
  }

  .t-track {
    display: flex;
    direction: ltr;
    gap: 1.25rem;
    width: max-content;
    animation: t-scroll-ltr 60s linear infinite;
  }

  :root[dir="rtl"] .t-card {
    direction: rtl;
    text-align: right;
  }
  .t-track:hover {
    animation-play-state: paused;
  }

  .t-card {
    flex-shrink: 0;
    width: min(82vw, 300px);
    background: white;
    border: 1px solid var(--color-midnight-100);
    border-top: 3px solid var(--color-saffron-400);
    border-radius: 2px;
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
  }
  @media (min-width: 640px) {
    .t-card { width: 360px; }
    .t-track { gap: 1.5rem; }
  }
  @media (min-width: 1024px) {
    .t-card { width: 400px; padding: 1.75rem 2rem 2rem; }
  }

  .t-quote {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-midnight-800);
    flex: 1;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .t-quote { font-size: 1rem; }
  }

  .t-footer {
    border-top: 1px solid var(--color-midnight-100);
    padding-top: 1rem;
  }
  .t-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-midnight-800);
  }
  .t-role {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.1875rem;
  }

  @keyframes t-scroll-ltr {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .t-track { animation: none; }
  }
</style>
