---
import { useTranslations, localePath } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const nav = t.nav as Record<string, string>;

const tiers = [
  {
    label: t.fees.students,
    inPerson: config.fees.studentInPerson,
    online: config.fees.studentOnline,
  },
  {
    label: t.fees.others,
    inPerson: config.fees.otherInPerson,
    online: config.fees.otherOnline,
  },
];
---

<section id="fees" class="py-12 md:py-20 lg:py-24 bg-surface-warm">
  <div class="container-wide">
    <div class="max-w-2xl mb-8 md:mb-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">
        {t.fees.kicker}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-semibold text-midnight-800 leading-tight">
        {t.fees.title}
      </h2>
      <p class="mt-3 md:mt-4 text-base md:text-lg text-muted">{t.fees.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 md:gap-5 md:gap-6">
      {tiers.map((tier) => (
        <article class="bg-white border border-midnight-100 p-5 md:p-7 md:p-8 rounded-sm">
          <h3 class="font-serif text-xl md:text-2xl text-midnight-800 mb-4 md:mb-6">{tier.label}</h3>
          <dl class="space-y-3 md:space-y-4">
            <div class="flex items-center justify-between border-b border-midnight-100 pb-3 md:pb-4">
              <dt class="text-sm md:text-base text-muted inline-flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-saffron-500 shrink-0" aria-hidden="true">
                  <path d="M12 21s-7-7.5-7-12a7 7 0 0 1 14 0c0 4.5-7 12-7 12z"/><circle cx="12" cy="9" r="2.5"/>
                </svg>
                {t.fees.inPerson}
              </dt>
              <dd class="font-serif text-2xl md:text-3xl text-midnight-800 tabular-nums">${tier.inPerson}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-sm md:text-base text-muted inline-flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-saffron-500 shrink-0" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                </svg>
                {t.fees.online}
              </dt>
              <dd class="font-serif text-2xl md:text-3xl text-midnight-800 tabular-nums">${tier.online}</dd>
            </div>
          </dl>
        </article>
      ))}
    </div>

    <div class="mt-6 md:mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 md:gap-5 bg-midnight-800 text-surface p-5 md:p-6 md:p-7 rounded-sm">
      <p class="text-sm md:text-base">
        <span class="ornament-star !w-3 !h-3 text-saffron-400 me-2 align-middle"></span>
        {t.fees.earlyBird}
      </p>
      <a href={config.paypalUrl} target="_blank" rel="noopener" class="btn btn-primary text-sm whitespace-nowrap self-start sm:self-auto">
        {t.fees.ctaRegister}
      </a>
    </div>

    <!-- In-person venue link -->
    <p class="mt-5 text-sm text-muted" data-reveal>
      {t.internal.inPersonCta}
      <a href={localePath(locale, "/venue")} class="ms-1 font-semibold text-saffron-600 hover:text-saffron-500 transition-colors">
        {nav.venue}
        <svg width="11" height="11" viewBox="0 0 13 13" fill="none" aria-hidden="true" class="inline-block ms-0.5 mb-0.5"><path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </p>
  </div>
</section>
