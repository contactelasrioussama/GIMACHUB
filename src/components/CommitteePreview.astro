---
import { useTranslations, localePath } from "~/i18n/utils";
import committee from "~/data/committee.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
type LocalKey = "en" | "ar";
const k: LocalKey = locale === "ar" ? "ar" : "en";
---

<section id="committee" class="relative overflow-hidden py-12 md:py-20 lg:py-24 bg-midnight-800 text-surface">

  <!-- ── Islamic 8-pointed star tile ─────────────────────────────── -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" aria-hidden="true">
    <defs>
      <pattern id="committee-stars" x="0" y="0" width="96" height="96" patternUnits="userSpaceOnUse">
        <polygon points="48,20 43.6,37.4 28.2,28.2 37.4,43.6 20,48 37.4,52.4 28.2,67.8 43.6,58.6 48,76 52.4,58.6 67.8,67.8 58.6,52.4 76,48 58.6,43.6 67.8,28.2 52.4,37.4" fill="#C9A94D"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#committee-stars)" />
  </svg>

  <!-- ── Decorative mandala (top-start corner) ───────────────────── -->
  <svg class="absolute -top-20 -start-20 w-[380px] h-[380px] opacity-[0.07] pointer-events-none text-saffron-400" viewBox="0 0 400 400" fill="none" aria-hidden="true">
    <circle cx="200" cy="200" r="185" stroke="currentColor" stroke-width="0.75"/>
    <circle cx="200" cy="200" r="110" stroke="currentColor" stroke-width="0.5"/>
    <circle cx="200" cy="200" r="55" stroke="currentColor" stroke-width="0.5"/>
    <circle cx="200" cy="200" r="5" fill="currentColor"/>
    <line x1="200" y1="200" x2="200" y2="15" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="200" y2="385" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="385" y2="200" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="15" y2="200" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="331" y2="69" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="69" y2="69" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="69" y2="331" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="331" y2="331" stroke="currentColor" stroke-width="0.5"/>
    <polygon points="200,35 174,137 83,83 137,174 35,200 137,226 83,317 174,263 200,365 226,263 317,317 263,226 365,200 263,174 317,83 226,137" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    <polygon points="200,90 183,158 122,122 158,183 90,200 158,217 122,278 183,242 200,310 217,242 278,278 242,217 310,200 242,183 278,122 217,158" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="0.75" stroke-linejoin="round"/>
    <polygon points="200,145 191,179 161,161 179,191 145,200 179,209 161,239 191,221 200,255 209,221 239,239 221,209 255,200 221,191 239,161 209,179" fill="currentColor" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
  </svg>

  <div class="container-wide relative z-10">

    <div class="max-w-3xl mb-10 md:mb-14" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-300 mb-4">
        {t.committee.kicker}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">
        {t.committee.title}
      </h2>
      <p class="mt-4 text-base md:text-lg text-surface/75 leading-relaxed">
        {t.committee.subtitle}
      </p>
    </div>

    <ul class="grid grid-cols-2 gap-3 sm:gap-5 md:gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {committee.chairs.map((chair, i) => (
        <li
          class="card-lift bg-midnight-700/40 border border-midnight-700 p-4 md:p-6 rounded-sm"
          data-reveal
          data-delay={i === 0 ? undefined : String(Math.min(i * 100, 500))}
        >
          <p class="text-[0.6rem] md:text-xs uppercase tracking-[0.14em] md:tracking-[0.16em] text-saffron-300 font-semibold leading-snug">
            {chair.role[k]}
          </p>
          <p class="font-serif text-base md:text-lg mt-2 leading-snug">{chair.name}</p>
          <p class="text-xs md:text-sm text-surface/65 mt-1 leading-snug">{chair.affiliation}</p>
          <p class="text-xs text-surface/50 mt-1.5">{chair.country[k]}</p>
        </li>
      ))}
    </ul>

    <div class="mt-8 md:mt-10 flex flex-wrap items-center justify-between gap-4" data-reveal data-delay="200">
      <p class="text-sm text-surface/70">
        <span class="font-medium text-surface">+ {committee.members.length}</span>
        {locale === "ar"
          ? " عضواً في اللجنة المنظمة من 12 دولة"
          : " more committee members across 12+ countries"}
      </p>
      <a
        href={localePath(locale, "/committee")}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-saffron-300 hover:text-saffron-200 transition-colors"
      >
        {t.internal.meetCommittee}
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>

  <!-- ── Decorative mandala (bottom-end accent) ──────────────────── -->
  <svg class="absolute -bottom-24 -end-24 w-[460px] h-[460px] opacity-[0.05] pointer-events-none text-saffron-400" viewBox="0 0 400 400" fill="none" aria-hidden="true">
    <circle cx="200" cy="200" r="185" stroke="currentColor" stroke-width="0.75"/>
    <polygon points="200,35 174,137 83,83 137,174 35,200 137,226 83,317 174,263 200,365 226,263 317,317 263,226 365,200 263,174 317,83 226,137" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    <polygon points="200,90 183,158 122,122 158,183 90,200 158,217 122,278 183,242 200,310 217,242 278,278 242,217 310,200 242,183 278,122 217,158" fill="currentColor" fill-opacity="0.06" stroke="currentColor" stroke-width="0.75" stroke-linejoin="round"/>
    <polygon points="200,145 191,179 161,161 179,191 145,200 179,209 161,239 191,221 200,255 209,221 239,239 221,209 255,200 221,191 239,161 209,179" fill="currentColor" stroke-width="0" />
  </svg>
</section>
