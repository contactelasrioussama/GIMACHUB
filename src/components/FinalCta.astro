---
import { useTranslations } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const submissionMailto = `mailto:${config.contact.chairEmail}?subject=${encodeURIComponent("GIMAC 17 — Paper Submission")}&body=${encodeURIComponent("Dear Prof. Alserhan,\n\nPlease find my paper attached for consideration at GIMAC 17.\n\nTitle:\nAuthor(s):\nAffiliation:\nTrack:\n\nKind regards,")}`;
const whatsappLink = `https://wa.me/${config.contact.whatsapp.replace(/\D/g, "")}?text=${encodeURIComponent("Hello, I have a question about GIMAC 17.")}`;
---

<section id="contact" class="relative overflow-hidden py-12 md:py-20 lg:py-28">

  <!-- ── Subtle Islamic mandala (centered, light section) ────────── -->
  <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] opacity-[0.04] pointer-events-none text-midnight-800" viewBox="0 0 400 400" fill="none" aria-hidden="true">
    <circle cx="200" cy="200" r="185" stroke="currentColor" stroke-width="1"/>
    <circle cx="200" cy="200" r="110" stroke="currentColor" stroke-width="0.75"/>
    <circle cx="200" cy="200" r="55" stroke="currentColor" stroke-width="0.75"/>
    <circle cx="200" cy="200" r="6" fill="currentColor"/>
    <line x1="200" y1="200" x2="200" y2="15" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="200" y2="385" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="385" y2="200" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="15" y2="200" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="331" y2="69" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="69" y2="69" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="69" y2="331" stroke="currentColor" stroke-width="0.75"/>
    <line x1="200" y1="200" x2="331" y2="331" stroke="currentColor" stroke-width="0.75"/>
    <polygon points="200,35 174,137 83,83 137,174 35,200 137,226 83,317 174,263 200,365 226,263 317,317 263,226 365,200 263,174 317,83 226,137" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
    <polygon points="200,90 183,158 122,122 158,183 90,200 158,217 122,278 183,242 200,310 217,242 278,278 242,217 310,200 242,183 278,122 217,158" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    <polygon points="200,145 191,179 161,161 179,191 145,200 179,209 161,239 191,221 200,255 209,221 239,239 221,209 255,200 221,191 239,161 209,179" fill="currentColor" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
  </svg>

  <div class="container-tight text-center px-6 md:px-0 relative z-10" data-reveal="scale">
    <span class="ornament-star !w-5 !h-5 md:!w-6 md:!h-6 text-saffron-400 inline-block mb-5 md:mb-6"></span>
    <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-semibold text-midnight-800 leading-tight">
      {t.finalCta.title}
    </h2>
    <p class="mt-4 text-base md:text-lg text-muted leading-relaxed">{t.finalCta.subtitle}</p>

    <div class="mt-8 md:mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <a href={submissionMailto} class="btn btn-dark w-full sm:w-auto justify-center">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"/>
          <path d="m3 7 9 6 9-6"/>
        </svg>
        {t.finalCta.submitBtn}
      </a>
      <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-primary w-full sm:w-auto justify-center">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.49 0 .14 5.34.14 11.91a11.85 11.85 0 0 0 1.6 5.96L0 24l6.27-1.65a11.92 11.92 0 0 0 5.78 1.47h.01c6.57 0 11.92-5.34 11.92-11.91a11.84 11.84 0 0 0-3.46-8.43Zm-8.46 18.31h-.01a9.9 9.9 0 0 1-5.04-1.38l-.36-.21-3.72.98 1-3.62-.24-.37a9.86 9.86 0 0 1-1.51-5.28c0-5.46 4.45-9.91 9.91-9.91a9.86 9.86 0 0 1 7.01 2.9 9.85 9.85 0 0 1 2.9 7.01c0 5.47-4.45 9.92-9.94 9.92Zm5.43-7.42c-.3-.15-1.76-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.18.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.21 5.08 4.5.71.31 1.27.49 1.7.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35Z"/>
        </svg>
        {t.finalCta.whatsappBtn}
      </a>
    </div>
  </div>
</section>
