---
import { useTranslations } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const items = [
  { type: "logo", name: "Scopus",                         logo: "/logos/scopus.svg",         url: "https://www.scopus.com" },
  { type: "logo", name: "Web of Science",                 logo: "/logos/web-of-science.svg", url: "https://www.webofscience.com" },
  { type: "logo", name: "Springer",                       logo: "/logos/springer.svg",       url: "https://link.springer.com" },
  { type: "logo", name: "EBSCO",                          logo: "/logos/ebsco.svg",          url: "https://www.ebsco.com" },
  { type: "logo", name: "Emerald Publishing",             logo: "/logos/emerald.svg",        url: "https://www.emeraldpublishing.com" },
  { type: "text", name: "ARCIF",                          url: "" },
  { type: "text", name: "IIMA",                           url: "https://islamicmarketingassociation.org" },
  { type: "text", name: "Alanya Alaaddin Keykubat Univ.", url: "https://www.alanya.edu.tr" },
  { type: "text", name: "University of Malaya",           url: "https://um.edu.my" },
  { type: "text", name: "King Abdulaziz University",      url: "https://www.kau.edu.sa" },
];
---

<section class="bg-surface-warm border-y border-midnight-100 py-7 md:py-9">

  <!-- Label -->
  <p class="strip-label">{t.trust.trustedBy}</p>

  <!-- Marquee -->
  <div class="marquee-outer mt-5" role="region" aria-label={t.trust.trustedBy}>

    <!-- First copy — accessible -->
    <div class="marquee-track">

      {items.map((item) => (
        <div class="marquee-item">
          {item.type === "logo" ? (
            <a href={item.url} target="_blank" rel="noopener noreferrer"
               aria-label={item.name} class="logo-link">
              <img src={item.logo} alt={item.name} loading="lazy" />
            </a>
          ) : item.url ? (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-chip">
              {item.name}
            </a>
          ) : (
            <span class="text-chip">{item.name}</span>
          )}
        </div>
      ))}

      <!-- Duplicate — decorative only, hidden from assistive tech -->
      {items.map((item) => (
        <div class="marquee-item" aria-hidden="true">
          {item.type === "logo" ? (
            <a href={item.url} target="_blank" rel="noopener noreferrer"
               tabindex="-1" class="logo-link">
              <img src={item.logo} alt="" loading="lazy" />
            </a>
          ) : item.url ? (
            <a href={item.url} target="_blank" rel="noopener noreferrer"
               tabindex="-1" class="text-chip">
              {item.name}
            </a>
          ) : (
            <span class="text-chip">{item.name}</span>
          )}
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  /* ── Label ───────────────────────────────────────────────────────── */
  .strip-label {
    text-align: center;
    font-size: 0.575rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-midnight-400);
  }

  /* ── Marquee outer — clips scroll + paints edge fades ────────────── */
  .marquee-outer {
    overflow: hidden;
    position: relative;
  }

  .marquee-outer::before,
  .marquee-outer::after {
    content: "";
    position: absolute;
    inset-block: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-outer::before {
    inset-inline-start: 0;
    background: linear-gradient(to right, var(--color-surface-warm, #faf8f5), transparent);
  }

  .marquee-outer::after {
    inset-inline-end: 0;
    background: linear-gradient(to left, var(--color-surface-warm, #faf8f5), transparent);
  }

  /* RTL: mirror the fades */
  :root[dir="rtl"] .marquee-outer::before {
    background: linear-gradient(to left, var(--color-surface-warm, #faf8f5), transparent);
  }
  :root[dir="rtl"] .marquee-outer::after {
    background: linear-gradient(to right, var(--color-surface-warm, #faf8f5), transparent);
  }

  /* ── Scrolling track ─────────────────────────────────────────────── */
  .marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marquee-ltr 34s linear infinite;
  }

  /* Pause on hover / keyboard focus */
  .marquee-outer:hover .marquee-track,
  .marquee-outer:focus-within .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-ltr {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  :root[dir="rtl"] .marquee-track {
    animation-name: marquee-rtl;
  }

  @keyframes marquee-rtl {
    from { transform: translateX(0); }
    to   { transform: translateX(50%); }
  }

  /* ── Individual item slot ────────────────────────────────────────── */
  .marquee-item {
    display: flex;
    align-items: center;
    padding-inline: 2.5rem;
    height: 44px;
    flex-shrink: 0;
    /* Thin vertical rule between items */
    border-inline-end: 1px solid var(--color-midnight-100);
  }

  /* ── Logo link ───────────────────────────────────────────────────── */
  .logo-link {
    display: block;
    width: 96px;
    height: 24px;
    flex-shrink: 0;
    outline-offset: 3px;
  }

  .logo-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    filter: grayscale(1) opacity(0.38);
    transition: filter 0.25s ease;
  }

  .logo-link:hover img,
  .logo-link:focus-visible img {
    filter: grayscale(0) opacity(1);
  }

  /* ── Text chip ───────────────────────────────────────────────────── */
  .text-chip {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-midnight-500);
    opacity: 0.45;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.18s ease, color 0.18s ease;
  }

  a.text-chip:hover,
  a.text-chip:focus-visible {
    opacity: 1;
    color: var(--color-midnight-800);
  }

  /* ── Reduced motion: static centred wrap ────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem 1.5rem;
    }

    .marquee-item {
      height: auto;
      padding: 0.5rem 1rem;
      border-inline-end: none;
    }

    .marquee-outer::before,
    .marquee-outer::after { display: none; }
  }
</style>
