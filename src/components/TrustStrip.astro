---
import { useTranslations } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

// cellW controls the individual logo cell width — narrows EBSCO
// whose square-ish viewBox (95×25) makes it visually bigger than the others
const indexed = [
  { name: "Scopus",         logo: "/logos/scopus.svg",         url: "https://www.scopus.com",       cellW: 80 },
  { name: "Web of Science", logo: "/logos/web-of-science.svg", url: "https://www.webofscience.com", cellW: 80 },
  { name: "EBSCO",          logo: "/logos/ebsco.svg",          url: "https://www.ebsco.com",        cellW: 56 },
];

const publishers = [
  { name: "Springer",           logo: "/logos/springer.svg", url: "https://link.springer.com",          cellW: 80 },
  { name: "Emerald Publishing", logo: "/logos/emerald.svg",  url: "https://www.emeraldpublishing.com",  cellW: 80 },
];
---

<section class="bg-surface-warm border-y border-midnight-100 py-8 md:py-10">
  <div class="container-wide">
    <div class="trust-grid">

      <!-- Column 1: Indexed in -->
      <div class="trust-col">
        <p class="col-label">{t.trust.indexedIn}</p>
        <ul class="logo-list">
          {indexed.map((item) => (
            <li>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.name}
                class="logo-cell"
                style={`width:${item.cellW}px`}
              >
                <img src={item.logo} alt={item.name} />
              </a>
            </li>
          ))}
          <li><span class="text-chip">ARCIF</span></li>
        </ul>
      </div>

      <!-- Column 2: Publishing partners -->
      <div class="trust-col">
        <p class="col-label">{t.trust.inPartnership}</p>
        <ul class="logo-list">
          {publishers.map((item) => (
            <li>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.name}
                class="logo-cell"
                style={`width:${item.cellW}px`}
              >
                <img src={item.logo} alt={item.name} />
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Grid: 1-col mobile → 2-col desktop ─────────────────────────── */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem 0;
  }

  @media (min-width: 640px) {
    .trust-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
  }

  /* ── Column ──────────────────────────────────────────────────────── */
  .trust-col {
    padding-inline-end: 1.5rem;
  }

  @media (min-width: 640px) {
    .trust-col {
      padding-inline: 2rem;
      border-inline-end: 1px solid var(--color-midnight-100);
    }
    .trust-col:first-child { padding-inline-start: 0; }
    .trust-col:last-child  { border-inline-end: none; padding-inline-end: 0; }
  }

  /* ── Section label ───────────────────────────────────────────────── */
  .col-label {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-midnight-400);
    margin-bottom: 0.875rem;
  }

  /* ── Logo list ───────────────────────────────────────────────────── */
  .logo-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Fixed-height cell, variable width set via inline style per logo */
  .logo-cell {
    display: block;
    height: 20px;
    outline-offset: 3px;
    flex-shrink: 0;
  }

  .logo-cell img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left center;
    filter: grayscale(1) opacity(0.45);
    transition: filter 0.25s ease;
  }

  :root[dir="rtl"] .logo-cell img {
    object-position: right center;
  }

  .logo-cell:hover img,
  .logo-cell:focus-visible img {
    filter: grayscale(0) opacity(1);
  }

  /* ── ARCIF text chip ─────────────────────────────────────────────── */
  .text-chip {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-midnight-600);
    opacity: 0.45;
  }
</style>
