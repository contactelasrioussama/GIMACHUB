---
import { useTranslations, localePath } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const nav = t.nav as Record<string, string>;
---

<section class="py-12 md:py-20 lg:py-24">
  <div class="container-wide">
    <div class="grid lg:grid-cols-12 gap-8 md:gap-10 lg:gap-16">

      <div class="lg:col-span-5" data-reveal="left">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">
          {t.deadlines.kicker}
        </p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-semibold text-midnight-800 leading-tight">
          {t.deadlines.title}
        </h2>
      </div>

      <div class="lg:col-span-7">
        <ol class="divide-y divide-midnight-100 border-y border-midnight-100">
          {t.deadlines.items.map((item, i) => (
            <li
              class="py-4 md:py-5 flex items-baseline justify-between gap-4"
              data-reveal
              data-delay={String(i * 100)}
            >
              <div class="flex items-baseline gap-3 md:gap-4 min-w-0">
                <span class="font-serif text-saffron-500 text-sm tabular-nums shrink-0">0{i + 1}</span>
                <span class="text-sm md:text-base lg:text-lg text-midnight-800">{item.label}</span>
              </div>
              <span class="font-serif text-sm md:text-base lg:text-lg font-medium text-midnight-800 whitespace-nowrap shrink-0">
                {item.date}
              </span>
            </li>
          ))}
        </ol>
      </div>

      <!-- CTA links below deadline list -->
      <div class="mt-8 flex flex-wrap items-center gap-3" data-reveal data-delay="200">
        <a href={localePath(locale, "/submit")} class="btn btn-primary text-sm">{nav.submit}</a>
        <a href="#fees" class="inline-flex items-center gap-1.5 text-sm font-medium text-midnight-600 hover:text-saffron-600 transition-colors">
          {t.internal.viewFees}
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>
