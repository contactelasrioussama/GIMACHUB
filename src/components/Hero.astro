---
import { useTranslations } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const submissionMailto = `mailto:${config.contact.chairEmail}?subject=${encodeURIComponent("GIMAC 17 — Paper Submission")}`;
---

<section class="relative overflow-hidden bg-midnight-800 text-surface lg:min-h-[660px]">

  <!-- ── Background decorations ───────────────────────────────────── -->
  <!-- Subtle star-polygon tile -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.035] pointer-events-none" aria-hidden="true">
    <defs>
      <pattern id="hero-stars" x="0" y="0" width="96" height="96" patternUnits="userSpaceOnUse">
        <polygon
          points="48,10 56,32 78,32 60,46 78,60 56,60 48,82 40,60 18,60 36,46 18,32 40,32"
          fill="#C9A94D"
        />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#hero-stars)" />
  </svg>

  <!-- Saffron top accent bar -->
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-saffron-400 to-transparent"></div>

  <!-- Radial breathing glow (text side only) -->
  <div class="glow-pulse absolute -top-32 start-[-10%] w-[700px] h-[700px] rounded-full bg-saffron-400/[0.06] blur-3xl pointer-events-none"></div>

  <!-- ── Right image panel (desktop) ──────────────────────────────── -->
  <div
    class="hidden lg:block absolute inset-y-0 end-0 w-[46%]"
    aria-hidden="true"
  >
    <!-- Blend edge: image fades into the dark left background -->
    <div class="absolute inset-y-0 start-0 w-2/5 bg-gradient-to-r from-midnight-800 via-midnight-800/70 to-transparent z-10"></div>
    <!-- Top + bottom fades -->
    <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-b from-midnight-800/60 to-transparent z-10"></div>
    <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-midnight-800/60 to-transparent z-10"></div>

    <img
      src="/images/hero-conference.jpg"
      alt=""
      class="w-full h-full object-cover object-[center_28%] opacity-75"
      loading="eager"
    />
  </div>

  <!-- ── Content ───────────────────────────────────────────────────── -->
  <div class="container-wide relative z-10 py-20 md:py-28 lg:py-32">
    <div class="max-w-xl lg:max-w-2xl">

      <p class="hero-anim inline-flex items-center gap-2 text-xs sm:text-sm font-medium uppercase tracking-[0.22em] text-saffron-300 mb-6" style="animation-delay:0.05s">
        <span class="ornament-star !w-3 !h-3"></span>
        {t.hero.kicker}
      </p>

      <h1 class="hero-anim font-serif text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-[1.05] tracking-tight" style="animation-delay:0.20s">
        {t.hero.title}
      </h1>

      <p class="hero-anim mt-6 text-lg sm:text-xl leading-relaxed text-surface/80 max-w-lg" style="animation-delay:0.35s">
        {t.hero.subtitle}
      </p>

      <div class="hero-anim mt-10 flex flex-wrap gap-3 sm:gap-4" style="animation-delay:0.50s">
        <a id="submit" href={submissionMailto} class="btn btn-primary text-base">
          {t.hero.ctaPrimary}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" class="rtl:hidden"/>
            <path d="M19 12H5M11 19l-7-7 7-7" class="hidden rtl:block"/>
          </svg>
        </a>
        <a href="#fees" class="btn btn-ghost text-base">{t.hero.ctaSecondary}</a>
      </div>

      <div class="hero-anim mt-12 pt-8 border-t border-surface/15 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm" style="animation-delay:0.65s">
        <span class="inline-flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-saffron-300" aria-hidden="true">
            <rect x="3" y="5" width="18" height="16" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="8" y1="3" x2="8" y2="7"/>
            <line x1="16" y1="3" x2="16" y2="7"/>
          </svg>
          <span class="font-medium">{t.hero.dates}</span>
        </span>
        <span class="text-surface/30">·</span>
        <span class="inline-flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-saffron-300" aria-hidden="true">
            <path d="M12 21s-7-7.5-7-12a7 7 0 0 1 14 0c0 4.5-7 12-7 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span class="font-medium">{t.hero.venue}</span>
        </span>
      </div>

    </div>

    <!-- ── Mobile image (below content on sm/md) ──────────────────── -->
    <div class="lg:hidden mt-14 -mx-4 sm:-mx-6 relative" aria-hidden="true">
      <div class="aspect-[16/7] overflow-hidden">
        <img
          src="/images/hero-conference.jpg"
          alt=""
          class="w-full h-full object-cover object-[center_28%] opacity-75"
          loading="eager"
        />
      </div>
      <!-- Bottom fade into page background -->
      <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-midnight-800 to-transparent"></div>
      <!-- Top fade -->
      <div class="absolute inset-x-0 top-0 h-10 bg-gradient-to-b from-midnight-800/40 to-transparent"></div>
    </div>

  </div>
</section>
