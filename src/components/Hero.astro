---
import { useTranslations } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const submissionMailto = `mailto:${config.contact.chairEmail}?subject=${encodeURIComponent("GIMAC 17 — Paper Submission")}`;
---

<section class="relative overflow-hidden bg-midnight-800 text-surface min-h-[600px] lg:min-h-[680px]">

  <!-- ── Full-bleed background image ──────────────────────────────── -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/images/hero-conference.jpg"
      alt=""
      class="w-full h-full object-cover object-[center_30%]"
      loading="eager"
    />
    <!-- Solid uniform dark overlay — no gradient -->
    <div class="absolute inset-0 bg-midnight-800/80"></div>
  </div>

  <!-- Saffron top accent bar -->
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-saffron-400 to-transparent"></div>

  <!-- Breathing radial glow -->
  <div class="glow-pulse absolute -top-32 start-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-saffron-400/[0.06] blur-3xl pointer-events-none"></div>

  <!-- ── Decorative Islamic mandala (corner accent) ────────────────── -->
  <svg class="absolute bottom-0 end-0 w-[420px] h-[420px] opacity-[0.08] pointer-events-none text-saffron-400" viewBox="0 0 400 400" fill="none" aria-hidden="true">
    <circle cx="200" cy="200" r="185" stroke="currentColor" stroke-width="0.75"/>
    <circle cx="200" cy="200" r="110" stroke="currentColor" stroke-width="0.5"/>
    <circle cx="200" cy="200" r="55" stroke="currentColor" stroke-width="0.5"/>
    <circle cx="200" cy="200" r="5" fill="currentColor"/>
    <line x1="200" y1="200" x2="200" y2="15" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="200" y2="385" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="385" y2="200" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="15" y2="200" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="331" y2="69" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="69" y2="69" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="69" y2="331" stroke="currentColor" stroke-width="0.5"/>
    <line x1="200" y1="200" x2="331" y2="331" stroke="currentColor" stroke-width="0.5"/>
    <polygon points="200,35 174,137 83,83 137,174 35,200 137,226 83,317 174,263 200,365 226,263 317,317 263,226 365,200 263,174 317,83 226,137" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    <polygon points="200,90 183,158 122,122 158,183 90,200 158,217 122,278 183,242 200,310 217,242 278,278 242,217 310,200 242,183 278,122 217,158" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="0.75" stroke-linejoin="round"/>
    <polygon points="200,145 191,179 161,161 179,191 145,200 179,209 161,239 191,221 200,255 209,221 239,239 221,209 255,200 221,191 239,161 209,179" fill="currentColor" stroke="currentColor" stroke-width="0.5" stroke-linejoin="round"/>
  </svg>

  <!-- ── Content ───────────────────────────────────────────────────── -->
  <div class="container-wide relative z-10 py-20 md:py-28 lg:py-32">
    <div class="max-w-3xl">

      <p class="hero-anim inline-flex items-center gap-2 text-xs sm:text-sm font-medium uppercase tracking-[0.22em] text-saffron-300 mb-6" style="animation-delay:0.05s">
        <span class="ornament-star !w-3 !h-3"></span>
        {t.hero.kicker}
      </p>

      <h1 class="hero-anim font-serif text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-[1.05] tracking-tight" style="animation-delay:0.20s">
        {t.hero.title}
      </h1>

      <p class="hero-anim mt-6 text-lg sm:text-xl leading-relaxed text-surface/80 max-w-2xl" style="animation-delay:0.35s">
        {t.hero.subtitle}
      </p>

      <div class="hero-anim mt-10 flex flex-wrap gap-3 sm:gap-4" style="animation-delay:0.50s">
        <a id="submit" href={submissionMailto} class="btn btn-primary text-base">
          {t.hero.ctaPrimary}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" class="rtl:hidden"/>
            <path d="M19 12H5M11 19l-7-7 7-7" class="hidden rtl:block"/>
          </svg>
        </a>
        <a href="#fees" class="btn btn-ghost text-base">{t.hero.ctaSecondary}</a>
      </div>

      <div class="hero-anim mt-12 pt-8 border-t border-surface/15 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm" style="animation-delay:0.65s">
        <span class="inline-flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-saffron-300" aria-hidden="true">
            <rect x="3" y="5" width="18" height="16" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="8" y1="3" x2="8" y2="7"/>
            <line x1="16" y1="3" x2="16" y2="7"/>
          </svg>
          <span class="font-medium">{t.hero.dates}</span>
        </span>
        <span class="text-surface/30">·</span>
        <span class="inline-flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-saffron-300" aria-hidden="true">
            <path d="M12 21s-7-7.5-7-12a7 7 0 0 1 14 0c0 4.5-7 12-7 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span class="font-medium">{t.hero.venue}</span>
        </span>
      </div>

    </div>
  </div>
</section>
