---
import { useTranslations } from "~/i18n/utils";

interface Props {
  variant?: "light" | "dark";
  showSubtitle?: boolean;
}

const { variant = "dark", showSubtitle = true } = Astro.props;
const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const ink     = variant === "light" ? "#F8F5EE"              : "#0A1F44";
const accent  = "#C9A94D";
const muted   = variant === "light" ? "rgba(248,245,238,0.55)" : "#8A94A6";

const subtitle = locale === "ar"
  ? "المؤتمر العالمي للتسويق الإسلامي"
  : "Global Islamic Marketing Conference";
---

<a
  href={locale === "ar" ? "/ar/" : "/"}
  class="inline-flex flex-col leading-none group select-none"
  aria-label={`GIMAC 17 — ${t.meta.siteFullName}`}
>
  <!-- Main wordmark -->
  <span class="flex items-baseline">
    <span
      class="font-serif font-bold tracking-tight transition-colors"
      style={`font-size:1.45rem; color:${ink};`}
    >GIMAC</span>
    <span
      class="font-serif font-bold align-super ms-[0.15em] transition-colors"
      style={`font-size:0.72rem; color:${accent}; line-height:1;`}
    >17</span>
  </span>

  <!-- Abbreviation line -->
  {showSubtitle && (
    <span
      class="hidden sm:block uppercase tracking-[0.22em] font-medium mt-[0.3em] transition-colors"
      style={`font-size:0.52rem; color:${muted}; letter-spacing:0.22em;`}
    >
      {subtitle}
    </span>
  )}
</a>
