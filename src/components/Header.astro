---
import Logo from "~/components/Logo.astro";
import LanguageSwitcher from "~/components/LanguageSwitcher.astro";
import { useTranslations, localePath } from "~/i18n/utils";
import config from "~/data/config.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const nav = t.nav as Record<string, string>;

const pathname = Astro.url.pathname;

// 5 nav links — Past & Gallery live in the footer
const navItems = [
  { key: "submit",       href: localePath(locale, "/submit") },
  { key: "publications", href: localePath(locale, "/publications") },
  { key: "blog",         href: localePath(locale, "/blog") },
  { key: "venue",        href: localePath(locale, "/venue") },
  { key: "committee",    href: localePath(locale, "/committee") },
];

function isActive(href: string) {
  return pathname === href || pathname === href + "/";
}
---

<header class="sticky top-0 z-50 backdrop-blur bg-[color-mix(in_srgb,var(--color-surface)_88%,transparent)] border-b border-midnight-100">
  <div class="container-wide flex items-center justify-between gap-4 py-3">
    <Logo variant="dark" />

    <nav class="hidden lg:flex items-center gap-7" aria-label="primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`text-sm font-medium transition-colors ${
            isActive(item.href)
              ? "nav-active"
              : "text-midnight-700 hover:text-midnight-900"
          }`}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {nav[item.key]}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3 sm:gap-4">
      <LanguageSwitcher variant="dark" />
      <!-- Register CTA → PayPal payment portal -->
      <a
        href={config.paypalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary text-sm hidden sm:inline-flex"
      >
        {t.nav.register}
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded text-midnight-800 hover:bg-midnight-50"
        data-mobile-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-nav" class="lg:hidden hidden border-t border-midnight-100 bg-surface">
    <nav class="container-wide flex flex-col py-4 gap-1" aria-label="mobile">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`px-2 py-3 text-base font-medium rounded transition-colors ${
            isActive(item.href)
              ? "text-midnight-900 bg-saffron-400/10"
              : "text-midnight-800 hover:bg-midnight-50"
          }`}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {nav[item.key]}
        </a>
      ))}
      <!-- Secondary links -->
      <a href={localePath(locale, "/past")}    class="px-2 py-3 text-sm text-midnight-600 hover:text-midnight-900 transition-colors">{nav.past}</a>
      <a href={localePath(locale, "/gallery")} class="px-2 py-3 text-sm text-midnight-600 hover:text-midnight-900 transition-colors">{nav.gallery}</a>
      <!-- Register CTA -->
      <a
        href={config.paypalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary mt-3 w-full justify-center"
      >
        {t.nav.register}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const panel = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    if (!panel) return;
    const isOpen = !panel.classList.contains("hidden");
    panel.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
