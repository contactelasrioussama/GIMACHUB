---
import { useTranslations, localePath } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const nav = t.nav as Record<string, string>;
---

<section class="py-12 md:py-20 lg:py-24 bg-surface-warm border-t border-midnight-100">
  <div class="container-tight">
    <div class="mb-10 md:mb-14">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">
        {t.faq.kicker}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-midnight-800 leading-tight">
        {t.faq.title}
      </h2>
    </div>

    <!-- Quick navigation above the accordion -->
    <div class="mb-8 flex flex-wrap items-center gap-x-5 gap-y-2" data-reveal>
      <span class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{t.internal.quickLinks}</span>
      {[
        { key: "venue",        href: localePath(locale, "/venue") },
        { key: "submit",       href: localePath(locale, "/submit") },
        { key: "publications", href: localePath(locale, "/publications") },
        { key: "committee",    href: localePath(locale, "/committee") },
        { key: "blog",         href: localePath(locale, "/blog") },
      ].map(({ key, href }) => (
        <a href={href} class="inline-flex items-center gap-1 text-sm font-medium text-midnight-700 hover:text-saffron-600 transition-colors">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 5h8M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {nav[key]}
        </a>
      ))}
    </div>

    <div class="faq-list">
      {t.faq.items.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-summary">
            <span class="faq-q">{item.q}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="faq-body">
            <p class="faq-a">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    border-top: 1px solid var(--color-midnight-100);
  }
  .faq-item {
    border-bottom: 1px solid var(--color-midnight-100);
  }

  .faq-summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-summary::-webkit-details-marker { display: none; }

  .faq-q {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-midnight-800);
    line-height: 1.45;
    padding-top: 0.1rem;
  }
  @media (min-width: 768px) {
    .faq-q { font-size: 1.125rem; }
    .faq-summary { padding: 1.5rem 0; }
  }

  .faq-chevron {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-saffron-500);
    transition: transform 0.22s ease;
  }
  details[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }
  details[open] .faq-body {
    max-height: 600px;
  }

  .faq-a {
    padding-bottom: 1.5rem;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-muted);
  }
  @media (min-width: 768px) {
    .faq-a { font-size: 1rem; }
  }
</style>
