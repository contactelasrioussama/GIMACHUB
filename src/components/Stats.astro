---
import { useTranslations, localePath } from "~/i18n/utils";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const nav = t.nav as Record<string, string>;

const calendarIcon = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>`;
const globeIcon    = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8"/><ellipse cx="12" cy="12" rx="4.5" ry="9"/></svg>`;
const bookIcon     = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 6s1.5-2 5-2 5 2 5 2v14s-1.5-2-5-2-5 2-5 2V6z"/><path d="M12 6s1.5-2 5-2 5 2 5 2v14s-1.5-2-5-2-5 2-5 2V6z"/></svg>`;
const awardIcon    = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="M8.5 14.5L7 22l5-3 5 3-1.5-7.5"/></svg>`;

const items = [
  { value: t.stats.yearsValue,     label: t.stats.yearsLabel,     href: localePath(locale, "/past"),         linkLabel: nav.past,         icon: calendarIcon },
  { value: t.stats.countriesValue, label: t.stats.countriesLabel, href: localePath(locale, "/committee"),    linkLabel: nav.committee,    icon: globeIcon    },
  { value: t.stats.outletsValue,   label: t.stats.outletsLabel,   href: localePath(locale, "/publications"), linkLabel: nav.publications, icon: bookIcon     },
  { value: t.stats.creditsValue,   label: t.stats.creditsLabel,   href: localePath(locale, "/submit"),       linkLabel: nav.submit,       icon: awardIcon    },
];
---

<section id="about" class="py-12 md:py-20 lg:py-24 bg-white">
  <div class="container-wide">
    <ul class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 lg:gap-4">
      {items.map((stat, i) => (
        <li
          class="border-s-2 border-saffron-400 ps-4 md:ps-6 group"
          data-reveal
          data-delay={i === 0 ? undefined : String(i * 150)}
        >
          <a href={stat.href} class="block">
            <div class="mb-2.5 text-saffron-400 opacity-70 group-hover:opacity-100 transition-opacity duration-150" set:html={stat.icon} />
            <div
              class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-midnight-800 leading-none tabular-nums group-hover:text-saffron-600 transition-colors duration-150"
              data-counter
            >
              {stat.value}
            </div>
            <div class="mt-2 md:mt-3 text-sm text-muted leading-snug max-w-[14ch] group-hover:text-midnight-700 transition-colors duration-150">
              {stat.label}
            </div>
            <div class="mt-1.5 flex items-center gap-1 text-xs font-semibold text-saffron-600 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M1.5 5.5h8M6.5 2.5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {stat.linkLabel}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  function initCounters() {
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]:not([data-counted])");
    if (!counters.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          io.unobserve(el);
          el.dataset.counted = "1";

          const original = el.textContent?.trim() ?? "";
          // Parse prefix / number / suffix  e.g. "15+" → ["", "15", "+"]
          const m = original.match(/^([^0-9]*)(\d+(?:\.\d+)?)(.*)$/);
          if (!m) return;

          const prefix  = m[1];
          const end     = parseFloat(m[2]);
          const suffix  = m[3];
          const isFloat = m[2].includes(".");
          const decimals = isFloat ? (m[2].split(".")[1]?.length ?? 0) : 0;

          const duration = 1400;
          const startTs  = performance.now();

          function tick(now: number) {
            const t = Math.min((now - startTs) / duration, 1);
            // ease-out cubic
            const eased   = 1 - Math.pow(1 - t, 3);
            const current = eased * end;
            el.textContent =
              prefix +
              (decimals ? current.toFixed(decimals) : Math.floor(current).toString()) +
              suffix;
            if (t < 1) requestAnimationFrame(tick);
          }

          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.5 }
    );

    counters.forEach((el) => io.observe(el));
  }

  initCounters();
  document.addEventListener("astro:page-load", initCounters);
</script>
