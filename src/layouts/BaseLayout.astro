---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import { useTranslations, getDirection } from "~/i18n/utils";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const locale = Astro.currentLocale ?? "en";
const dir = getDirection(locale);
const t = useTranslations(locale);

const {
  title = `${t.meta.siteName} — ${t.meta.siteFullName}`,
  description = t.hero.subtitle,
  ogImage = "/og-default.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={locale === "ar" ? "ar_SA" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/ar/, "") || "/", Astro.site).toString()} />
    <link rel="alternate" hreflang="ar" href={new URL(`/ar${Astro.url.pathname.replace(/^\/ar/, "") || "/"}`.replace(/\/+$/, "/"), Astro.site).toString()} />
    <link rel="alternate" hreflang="x-default" href={Astro.site} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Amiri:wght@400;700&family=Cairo:wght@400;500;600;700&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Smooth page transitions -->
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal: watches [data-reveal] elements and adds .is-visible -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll("[data-reveal]:not(.is-visible)");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -48px 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
      // Initial load + after every View Transition navigation
      initReveal();
      document.addEventListener("astro:page-load", initReveal);
    </script>
  </body>
</html>
