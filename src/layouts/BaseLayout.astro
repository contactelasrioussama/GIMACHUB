---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import { useTranslations, getDirection } from "~/i18n/utils";
import config from "~/data/config.json";

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile" | "event";
  keywords?: string;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  articleSection?: string;
  articleTags?: string[];
  breadcrumbs?: Breadcrumb[];
  extraJsonLd?: Record<string, unknown>[];
  preloadHero?: boolean;
  canonicalOverride?: string;
  /** Set to false on EN-only pages (e.g. /blog/*) — suppresses AR hreflang to avoid sending Google to a 404 */
  hasArVersion?: boolean;
}

const locale = Astro.currentLocale ?? "en";
const dir = getDirection(locale);
const t = useTranslations(locale);

const siteName = `${t.meta.siteName} — ${t.meta.siteFullName}`;

const defaultKeywords = locale === "ar"
  ? "التسويق الإسلامي, الاقتصاد الحلال, سلوك المستهلك المسلم, الأعمال الأخلاقية, التمويل الإسلامي, السياحة الحلال, مؤتمر جيماك, ألانيا, تركيا, 2026"
  : "Islamic marketing, halal economy, Muslim consumer behaviour, ethical business, Islamic finance, halal tourism, GIMAC conference, GIMAC 17, Alanya, Turkey, 2026, academic conference, marketing research, hybrid conference";

const {
  title = siteName,
  description = t.hero.subtitle,
  ogImage = "/images/hero-conference.jpg",
  ogType = "website",
  keywords = defaultKeywords,
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  articleSection,
  articleTags = [],
  breadcrumbs,
  extraJsonLd = [],
  preloadHero = false,
  canonicalOverride,
  hasArVersion = true,
} = Astro.props;

// ── URLs & hreflang ─────────────────────────────────────────────────────
const cleanPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonical = canonicalOverride
  ? canonicalOverride
  : new URL(cleanPath === "/" ? "/" : cleanPath + "/", Astro.site).toString();

// Strip /ar prefix to get the EN path; AR home is /ar/
const enPath = cleanPath.replace(/^\/ar/, "") || "/";
const arPath = enPath === "/" ? "/ar/" : `/ar${enPath}/`;
const enHref = new URL(enPath === "/" ? "/" : enPath + "/", Astro.site).toString();
const arHref = new URL(arPath, Astro.site).toString();

const fullOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, Astro.site).toString();

// ── Structured data ─────────────────────────────────────────────────────

// 1. Organization (always)
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://gimachub.com/#organization",
  "name": "International Islamic Marketing Association (IIMA)",
  "alternateName": ["IIMA", "GIMAC"],
  "url": "https://islamicmarketingassociation.org",
  "logo": {
    "@type": "ImageObject",
    "url": new URL("/logos/iima.svg", Astro.site).toString(),
    "width": 200,
    "height": 200,
  },
  "sameAs": [
    "https://islamicmarketingassociation.org",
    "https://gimachub.com",
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": config.contact.chairEmail,
    "contactType": "Conference Chair",
    "availableLanguage": ["English", "Arabic"],
  },
};

// 2. WebSite (always) — supports sitelinks search box
const webSiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://gimachub.com/#website",
  "url": "https://gimachub.com",
  "name": siteName,
  "description": t.hero.subtitle,
  "inLanguage": ["en", "ar"],
  "publisher": { "@id": "https://gimachub.com/#organization" },
};

// 3. Conference Event (always)
const eventJsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  "@id": "https://gimachub.com/#event",
  "name": "GIMAC 17 — 17th Global Islamic Marketing Conference",
  "alternateName": "17th GIMAC",
  "description": t.hero.subtitle,
  "url": "https://gimachub.com/",
  "startDate": config.conferenceDates.start,
  "endDate": config.conferenceDates.end,
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
  "location": [
    {
      "@type": "Place",
      "name": config.venue.name,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cleopatra Beach",
        "addressLocality": config.venue.city,
        "addressRegion": "Antalya",
        "addressCountry": "TR",
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.5444,
        "longitude": 31.9967,
      },
    },
    {
      "@type": "VirtualLocation",
      "url": "https://gimachub.com/submit/",
    },
  ],
  "organizer": { "@id": "https://gimachub.com/#organization" },
  "offers": [
    {
      "@type": "Offer",
      "name": "In-Person Registration (Standard)",
      "price": String(config.fees.otherInPerson),
      "priceCurrency": config.fees.currency,
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
      "url": "https://gimachub.com/submit/",
      "category": "Registration",
    },
    {
      "@type": "Offer",
      "name": "Online Registration",
      "price": String(config.fees.otherOnline),
      "priceCurrency": config.fees.currency,
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
      "url": "https://gimachub.com/submit/",
      "category": "Registration",
    },
    {
      "@type": "Offer",
      "name": "Student In-Person Registration",
      "price": String(config.fees.studentInPerson),
      "priceCurrency": config.fees.currency,
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
      "url": "https://gimachub.com/submit/",
      "category": "Student Registration",
    },
  ],
  "image": new URL("/images/hero-conference.jpg", Astro.site).toString(),
  "inLanguage": ["en", "ar"],
  "keywords": "Islamic marketing, halal economy, Muslim consumer behaviour, academic conference",
};

// 4. Breadcrumbs (when provided)
let breadcrumbJsonLd: Record<string, unknown> | null = null;
if (breadcrumbs && breadcrumbs.length) {
  breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((bc, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": bc.name,
      "item": bc.url.startsWith("http")
        ? bc.url
        : new URL(bc.url.endsWith("/") ? bc.url : bc.url + "/", Astro.site).toString(),
    })),
  };
}

const allJsonLd: Record<string, unknown>[] = [orgJsonLd, webSiteJsonLd, eventJsonLd];
if (breadcrumbJsonLd) allJsonLd.push(breadcrumbJsonLd);
if (extraJsonLd && extraJsonLd.length) allJsonLd.push(...extraJsonLd);

const robotsValue = noindex
  ? "noindex, nofollow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0A1F44" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {author && <meta name="author" content={author} />}
    <meta name="publisher" content="International Islamic Marketing Association (IIMA)" />
    <meta name="robots" content={robotsValue} />
    <meta name="googlebot" content={robotsValue} />
    <meta name="bingbot" content={robotsValue} />

    <link rel="canonical" href={canonical} />

    <!-- Geo signals (conference location) -->
    <meta name="geo.region" content="TR-07" />
    <meta name="geo.placename" content="Alanya, Antalya, Türkiye" />
    <meta name="geo.position" content="36.5444;31.9967" />
    <meta name="ICBM" content="36.5444, 31.9967" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType === "event" ? "website" : ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === "ar" ? "ar_SA" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "ar" ? "en_US" : "ar_SA"} />

    {/* Article tags (when this is an article) */}
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && author && (
      <meta property="article:author" content={author} />
    )}
    {ogType === "article" && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === "article" && articleTags.length > 0 && articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Hreflang (only emit AR when an AR version actually exists) -->
    <link rel="alternate" hreflang="en" href={enHref} />
    {hasArVersion && <link rel="alternate" hreflang="ar" href={arHref} />}
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://maps.google.com" />
    <link rel="dns-prefetch" href="https://www.iimassociation.com" />

    {/* Preload hero image on the homepage for LCP */}
    {preloadHero && (
      <link rel="preload" as="image" href="/images/hero-conference.jpg" fetchpriority="high" />
    )}

    <!-- Fonts -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Amiri:wght@400;700&family=Cairo:wght@400;500;600;700&display=swap"
    />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#C9A94D" />

    <!-- Sitemap discovery -->
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />

    <!-- Structured data — Organization, WebSite, Event (+ per-page extras) -->
    {allJsonLd.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Smooth page transitions -->
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">
      {locale === "ar" ? "تخطّى إلى المحتوى الرئيسي" : "Skip to main content"}
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal: watches [data-reveal] elements and adds .is-visible -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll("[data-reveal]:not(.is-visible)");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -48px 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
      // Initial load + after every View Transition navigation
      initReveal();
      document.addEventListener("astro:page-load", initReveal);
    </script>
  </body>
</html>

<style is:global>
  /* Skip-to-main-content link (visible only on keyboard focus) */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    padding: 0.75rem 1.25rem;
    background: #0A1F44;
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }
  .skip-link:focus {
    left: 0;
    outline: 2px solid #C9A94D;
    outline-offset: 2px;
  }
</style>
