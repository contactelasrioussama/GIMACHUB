---
import BaseLayout from "~/layouts/BaseLayout.astro";
import FinalCta from "~/components/FinalCta.astro";
import { useTranslations, localePath } from "~/i18n/utils";
import config from "~/data/config.json";
import themesData from "~/data/themes.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
type LocalKey = "en" | "ar";
const k: LocalKey = locale === "ar" ? "ar" : "en";
const sp = t.submitPage;

const submissionMailto = `mailto:${config.contact.chairEmail}?subject=${encodeURIComponent("GIMAC 17 — Paper Submission")}&body=${encodeURIComponent("Dear Prof. Alserhan,\n\nPlease find my paper attached for consideration at GIMAC 17.\n\nTitle:\nAuthor(s):\nAffiliation:\nTrack:\n\nKind regards,")}`;
const whatsappLink = `https://wa.me/${config.contact.whatsapp.replace(/\D/g, "")}?text=${encodeURIComponent("Hello, I have a question about GIMAC 17.")}`;
---

<BaseLayout title={`${sp.title} — GIMAC 17`} description={sp.subtitle}>

  <!-- Page hero -->
  <section class="bg-surface-warm py-14 md:py-20 border-b border-midnight-100">
    <div class="container-tight">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">{sp.kicker}</p>
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-semibold text-midnight-800 leading-tight">
        {sp.title}
      </h1>
      <p class="mt-4 text-base md:text-lg text-muted leading-relaxed max-w-2xl">{sp.subtitle}</p>
      <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-saffron-400/5 border border-saffron-400 rounded-sm text-sm text-saffron-600 font-medium">
        <span class="ornament-star !w-3 !h-3 text-saffron-500 shrink-0"></span>
        {sp.deadlineChip}
      </div>
    </div>
  </section>

  <!-- Steps + format -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="container-tight">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">

        <!-- Steps -->
        <div>
          <h2 class="font-serif text-xl md:text-2xl font-semibold text-midnight-800 mb-7">{sp.howTitle}</h2>
          <ol class="space-y-5">
            {sp.steps.map((step, i) => (
              <li class="ps-4 border-s border-saffron-400">
                <p class="text-[0.65rem] font-bold uppercase tracking-widest text-saffron-600 mb-1">
                  {locale === "ar" ? `الخطوة ${i + 1}` : `Step ${i + 1}`}
                </p>
                <p class="text-sm md:text-base text-midnight-700 leading-relaxed">{step}</p>
              </li>
            ))}
          </ol>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href={submissionMailto} class="btn btn-dark w-full sm:w-auto justify-center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="m3 7 9 6 9-6"/>
              </svg>
              {sp.cta}
            </a>
            <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-ghost w-full sm:w-auto justify-center text-sm">
              {sp.whatsappCta}
            </a>
          </div>
        </div>

        <!-- Format requirements -->
        <div>
          <h2 class="font-serif text-xl md:text-2xl font-semibold text-midnight-800 mb-7">{sp.formatTitle}</h2>
          <dl class="divide-y divide-midnight-100">
            {sp.format.map((row) => (
              <div class="py-3.5 flex justify-between gap-6">
                <dt class="text-sm text-muted shrink-0">{row.label}</dt>
                <dd class="text-sm text-midnight-800 font-medium text-end">{row.value}</dd>
              </div>
            ))}
          </dl>
        </div>

      </div>
    </div>
  </section>

  <!-- Research tracks -->
  <section class="py-12 md:py-16 bg-surface-warm border-t border-midnight-100">
    <div class="container-wide">
      <h2 class="font-serif text-xl md:text-2xl lg:text-3xl font-semibold text-midnight-800 mb-8">{sp.tracksTitle}</h2>
      <div class="space-y-8">
        {themesData.groups.map((group) => (
          <div>
            <div class="flex items-center gap-2 mb-3">
              {group.highlight && (
                <span class="ornament-star !w-3.5 !h-3.5 text-saffron-400 shrink-0"></span>
              )}
              <h3 class={`font-serif text-base md:text-lg font-semibold ${group.highlight ? "text-saffron-600" : "text-midnight-800"}`}>
                {group.title[k]}
              </h3>
            </div>
            <ul class="flex flex-wrap gap-2">
              {group.topics.map((topic) => (
                <li class={`px-3 py-1 text-xs md:text-sm rounded-sm border ${
                  group.highlight
                    ? "bg-saffron-400/5 border-saffron-400 text-saffron-600"
                    : "bg-white border-midnight-100 text-midnight-700"
                }`}>
                  {topic[k]}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
