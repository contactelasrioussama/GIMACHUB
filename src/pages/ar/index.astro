---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Countdown from "~/components/Countdown.astro";
import TrustStrip from "~/components/TrustStrip.astro";
import Stats from "~/components/Stats.astro";
import Themes from "~/components/Themes.astro";
import Deadlines from "~/components/Deadlines.astro";
import Fees from "~/components/Fees.astro";
import PastConferences from "~/components/PastConferences.astro";
import CommitteePreview from "~/components/CommitteePreview.astro";
import FeaturedArticles from "~/components/FeaturedArticles.astro";
import Testimonials from "~/components/Testimonials.astro";
import Faq from "~/components/Faq.astro";
import FinalCta from "~/components/FinalCta.astro";
import { useTranslations } from "~/i18n/utils";

const t = useTranslations("ar");

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<BaseLayout
  title="جيماك 17 — المؤتمر العالمي السابع عشر للتسويق الإسلامي · ألانيا، تركيا · أكتوبر 2026"
  description="المؤتمر العالمي السابع عشر للتسويق الإسلامي يجمع الباحثين والممارسين وصانعي السياسات لمناقشة الاقتصاد الحلال والتسويق الأخلاقي وسلوك المستهلك المسلم. ألانيا، تركيا، 27-28 أكتوبر 2026 — صيغة هجينة."
  keywords="جيماك 17, المؤتمر العالمي للتسويق الإسلامي, ألانيا 2026, تركيا, الاقتصاد الحلال, التسويق الإسلامي, سلوك المستهلك المسلم, التمويل الإسلامي, الأعمال الأخلاقية, السياحة الحلال, الجمعية الدولية للتسويق الإسلامي"
  preloadHero={true}
  extraJsonLd={[faqJsonLd]}
>
  <Hero />
  <Countdown />
  <TrustStrip />
  <Stats />
  <Themes />
  <Deadlines />
  <Fees />
  <PastConferences />
  <CommitteePreview />
  <FeaturedArticles />
  <Testimonials />
  <Faq />
  <FinalCta />
</BaseLayout>
