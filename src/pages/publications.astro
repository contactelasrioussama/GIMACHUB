---
import BaseLayout from "~/layouts/BaseLayout.astro";
import FinalCta from "~/components/FinalCta.astro";
import { useTranslations } from "~/i18n/utils";
import publicationsData from "~/data/publications.json";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const pp = t.publicationsPage;
---

<BaseLayout title={`${pp.title} — GIMAC 17`} description={pp.subtitle}>

  <!-- Page hero -->
  <section class="bg-surface-warm py-14 md:py-20 border-b border-midnight-100">
    <div class="container-tight">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-saffron-600 mb-4">{pp.kicker}</p>
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-semibold text-midnight-800 leading-tight">
        {pp.title}
      </h1>
      <p class="mt-4 text-base md:text-lg text-muted leading-relaxed max-w-2xl">{pp.subtitle}</p>
    </div>
  </section>

  <!-- Outlets list -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="container-tight">
      <ol class="space-y-3">
        {publicationsData.outlets.map((outlet, i) => (
          <li class="bg-white border border-midnight-100 rounded-sm p-5 md:p-6 flex gap-4 md:gap-5 items-start">
            <span class="shrink-0 font-serif text-2xl md:text-3xl text-[#B6C0D6] leading-none w-8 md:w-10 tabular-nums">
              {i + 1}
            </span>
            <div class="flex-1 min-w-0">
              <p class="font-serif text-base md:text-lg font-semibold text-midnight-800 leading-snug mb-2">
                {outlet.title}
              </p>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
                <span class="text-xs font-semibold text-midnight-400 uppercase tracking-wide">
                  {outlet.publisher}
                </span>
                <span class="text-[#B6C0D6] hidden sm:inline" aria-hidden="true">·</span>
                <div class="flex flex-wrap gap-1.5">
                  {outlet.indexing.map((idx) => (
                    <span class="text-[0.6rem] font-bold uppercase tracking-widest px-1.5 py-0.5 bg-midnight-800 text-saffron-300 rounded-sm">
                      {idx}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))}
      </ol>

      <!-- How it works -->
      <div class="mt-10 md:mt-14 bg-midnight-800 rounded-sm p-6 md:p-8">
        <div class="flex gap-3 items-start">
          <span class="ornament-star !w-4 !h-4 text-saffron-400 shrink-0 mt-1"></span>
          <div>
            <h2 class="font-serif text-lg md:text-xl font-semibold text-saffron-300 mb-2">{pp.noteTitle}</h2>
            <p class="text-sm md:text-base text-surface/80 leading-relaxed">{pp.note}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
