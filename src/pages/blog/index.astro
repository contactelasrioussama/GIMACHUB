---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

// Sort by date descending
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = posts.find(p => p.data.featured) ?? posts[0];
const grid     = posts.filter(p => p.slug !== featured.slug);

// Category → accent colours
const catStyle: Record<string, { bg: string; label: string; overlay: string }> = {
  Research:         { bg: "#0A1F44", label: "#C9A94D",  overlay: "rgba(10,31,68,0.78)"   },
  Marketing:        { bg: "#78350F", label: "#FDE68A",  overlay: "rgba(120,53,15,0.78)"  },
  Technology:       { bg: "#0F4C5C", label: "#67E8F9",  overlay: "rgba(15,76,92,0.78)"   },
  Finance:          { bg: "#1E3A8A", label: "#93C5FD",  overlay: "rgba(30,58,138,0.78)"  },
  Entrepreneurship: { bg: "#4C1D95", label: "#DDD6FE",  overlay: "rgba(76,29,149,0.78)"  },
  Sustainability:   { bg: "#064E3B", label: "#6EE7B7",  overlay: "rgba(6,78,59,0.78)"    },
};

function cat(category: string) {
  return catStyle[category] ?? { bg: "#243A6B", label: "#C9A94D", overlay: "rgba(36,58,107,0.78)" };
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric",
  });
}
---

<BaseLayout
  title="Research & Insights — GIMAC 17"
  description="Latest thinking on Islamic marketing, halal economy, sustainable finance, and Muslim consumer behaviour from the GIMAC research community."
>

  <!-- ── Page header ────────────────────────────────────────────────── -->
  <section class="bg-midnight-800 py-14 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div style="position:absolute;right:-80px;top:-80px;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,rgba(201,169,77,0.08) 0%,transparent 70%)"></div>
      <div style="position:absolute;left:-60px;bottom:-60px;width:280px;height:280px;border-radius:50%;background:radial-gradient(circle,rgba(201,169,77,0.05) 0%,transparent 70%)"></div>
    </div>
    <div class="container-wide relative">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-saffron-400 mb-4">Research & Insights</p>
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight max-w-2xl">
        Ideas Shaping the Islamic Economy
      </h1>
      <p class="mt-4 text-base md:text-lg leading-relaxed max-w-xl" style="color:rgba(255,255,255,0.65)">
        Perspectives from the GIMAC research community on Islamic marketing,
        halal finance, Muslim consumer behaviour, and sustainable business.
      </p>
    </div>
  </section>

  <!-- ── Featured article ──────────────────────────────────────────── -->
  <section class="py-10 md:py-14" style="background:#F1ECDF">
    <div class="container-wide">

      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-midnight-500 mb-5">Featured Article</p>

      <a
        href={`/blog/${featured.slug}`}
        class="group block relative rounded-sm overflow-hidden card-lift"
        style="min-height:340px"
        data-reveal
      >
        <!-- Cover image -->
        {featured.data.cover && (
          <img
            src={featured.data.cover}
            alt=""
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            aria-hidden="true"
          />
        )}
        <!-- Category-tinted overlay -->
        <div
          class="absolute inset-0"
          style={`background:${cat(featured.data.category).overlay.replace("0.78","0.85")}`}
        ></div>
        <!-- Gradient darken on left for readability -->
        <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(0,0,0,0.35) 0%,transparent 60%)"></div>

        <!-- Content -->
        <div class="relative grid md:grid-cols-12 gap-0 h-full">
          <div class="md:col-span-8 p-8 md:p-12 lg:p-14 flex flex-col justify-between" style="min-height:340px">

            <div>
              <!-- badges -->
              <div class="flex items-center gap-3 mb-5">
                <span
                  class="text-xs font-bold uppercase tracking-[0.18em] px-2.5 py-1 rounded-sm"
                  style={`background:rgba(255,255,255,0.15); color:${cat(featured.data.category).label}`}
                >
                  {featured.data.category}
                </span>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-saffron-400">★ Featured</span>
              </div>

              <h2 class="font-serif text-2xl md:text-3xl lg:text-[2rem] font-bold text-white leading-tight mb-4
                          group-hover:text-saffron-200 transition-colors duration-200 max-w-2xl">
                {featured.data.title}
              </h2>
              <p class="text-base leading-relaxed max-w-2xl" style="color:rgba(255,255,255,0.75)">
                {featured.data.description}
              </p>
            </div>

            <div class="mt-8 flex flex-wrap items-center gap-5">
              <p class="text-xs font-medium" style="color:rgba(255,255,255,0.5)">{formatDate(featured.data.date)}</p>
              <span style="color:rgba(255,255,255,0.2)">·</span>
              <p class="text-xs font-medium" style="color:rgba(255,255,255,0.5)">{featured.data.readTime} min read</p>
              <span style="color:rgba(255,255,255,0.2)">·</span>
              <p class="text-xs font-semibold text-white">{featured.data.author}</p>
              <div class="ml-auto flex items-center gap-2 text-sm font-semibold text-saffron-300
                          group-hover:gap-4 transition-all duration-200">
                Read article
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>

          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ── Article grid ──────────────────────────────────────────────── -->
  <section class="pb-16 md:pb-24" style="background:#F1ECDF">
    <div class="container-wide">

      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif text-xl font-semibold text-midnight-800">More Articles</h2>
        <span class="text-xs text-muted font-medium uppercase tracking-[0.16em]">{grid.length} articles</span>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {grid.map((post, i) => {
          const c = cat(post.data.category);
          return (
            <article
              class="group bg-white rounded-sm overflow-hidden shadow-sm card-lift flex flex-col"
              data-reveal
              data-delay={String(Math.min((i % 3) * 100, 200))}
            >
              <!-- Cover image header -->
              <a href={`/blog/${post.slug}`} class="block relative overflow-hidden" style="height:168px">
                {post.data.cover ? (
                  <>
                    <img
                      src={post.data.cover}
                      alt=""
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      aria-hidden="true"
                    />
                    {/* Category overlay — light tint only */}
                    <div class="absolute inset-0" style={`background:${c.overlay.replace("0.78","0.52")}`}></div>
                  </>
                ) : (
                  <div class="w-full h-full" style={`background:${c.bg}`}></div>
                )}

                <!-- Category pill — always on top of image -->
                <span
                  class="absolute top-3 left-4 text-xs font-bold uppercase tracking-[0.15em] px-2.5 py-1 rounded-sm"
                  style={`background:rgba(0,0,0,0.45); backdrop-filter:blur(4px); color:${c.label}`}
                >
                  {post.data.category}
                </span>
                <!-- Read time -->
                <span
                  class="absolute top-3 right-4 text-xs font-medium"
                  style="color:rgba(255,255,255,0.75)"
                >
                  {post.data.readTime} min
                </span>
              </a>

              <!-- Card body -->
              <div class="flex flex-col flex-1 p-5">
                <a href={`/blog/${post.slug}`} class="flex flex-col flex-1">
                  <h3
                    class="font-serif text-base md:text-[1.05rem] font-semibold text-midnight-800
                           leading-snug mb-2 group-hover:text-saffron-600 transition-colors duration-150"
                  >
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-muted leading-relaxed line-clamp-3 flex-1">
                    {post.data.description}
                  </p>

                  <!-- Footer -->
                  <div class="mt-4 pt-4 border-t border-midnight-50 flex items-center justify-between gap-2">
                    <p class="text-xs font-semibold text-midnight-600">{post.data.author}</p>
                    <p class="text-xs text-muted shrink-0">{formatDate(post.data.date)}</p>
                  </div>
                </a>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── CTA strip ─────────────────────────────────────────────────── -->
  <section class="bg-midnight-800 py-14 md:py-16">
    <div class="container-wide text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-saffron-400 mb-3">
        GIMAC 17 · Alanya, Turkey · October 2026
      </p>
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">
        Present your research at GIMAC 17
      </h2>
      <p class="text-base max-w-xl mx-auto mb-8" style="color:rgba(255,255,255,0.65)">
        Submit your paper on Islamic marketing, halal economy, sustainable business,
        or Muslim consumer behaviour. Abstract deadline: 30 June 2026.
      </p>
      <a href="/submit" class="btn btn-primary">Submit a Paper</a>
    </div>
  </section>

</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
