---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

// Sort by date descending
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = posts.find(p => p.data.featured) ?? posts[0];
const grid     = posts.filter(p => p.slug !== featured.slug);

// Category → accent colours (bg, text label)
const catStyle: Record<string, { bg: string; label: string }> = {
  Research:       { bg: "#0A1F44", label: "#C9A94D" },
  Marketing:      { bg: "#78350F", label: "#FDE68A" },
  Technology:     { bg: "#0F4C5C", label: "#67E8F9" },
  Finance:        { bg: "#1E3A8A", label: "#93C5FD" },
  Entrepreneurship: { bg: "#4C1D95", label: "#DDD6FE" },
  Sustainability: { bg: "#064E3B", label: "#6EE7B7" },
};

function cat(category: string) {
  return catStyle[category] ?? { bg: "#243A6B", label: "#C9A94D" };
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric",
  });
}
---

<BaseLayout
  title="Research & Insights — GIMAC 17"
  description="Latest thinking on Islamic marketing, halal economy, sustainable finance, and Muslim consumer behaviour from the GIMAC research community."
>

  <!-- ── Page header ────────────────────────────────────────────────── -->
  <section class="bg-midnight-800 py-14 md:py-20 relative overflow-hidden">
    <!-- subtle geometric accent -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div style="
        position:absolute; right:-80px; top:-80px;
        width:360px; height:360px; border-radius:50%;
        background: radial-gradient(circle, rgba(201,169,77,0.08) 0%, transparent 70%);
      "></div>
      <div style="
        position:absolute; left:-60px; bottom:-60px;
        width:280px; height:280px; border-radius:50%;
        background: radial-gradient(circle, rgba(201,169,77,0.05) 0%, transparent 70%);
      "></div>
    </div>

    <div class="container-wide relative">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-saffron-400 mb-4">
        Research & Insights
      </p>
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight max-w-2xl">
        Ideas Shaping the Islamic Economy
      </h1>
      <p class="mt-4 text-base md:text-lg leading-relaxed max-w-xl" style="color:rgba(255,255,255,0.65)">
        Perspectives from GIMAC scholars and practitioners on Islamic marketing,
        halal finance, Muslim consumer behaviour, and sustainable business.
      </p>
    </div>
  </section>

  <!-- ── Featured article ──────────────────────────────────────────── -->
  <section class="py-10 md:py-14" style="background:#F8F5EE">
    <div class="container-wide">
      <a
        href={`/blog/${featured.slug}`}
        class="group block relative rounded-sm overflow-hidden"
        style={`background:${cat(featured.data.category).bg}`}
        data-reveal
      >
        <!-- decorative band -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
          <div style="
            position:absolute; right:0; top:0; bottom:0; width:40%;
            background: linear-gradient(to left, rgba(255,255,255,0.03), transparent);
          "></div>
          <div style="
            position:absolute; right:60px; top:-60px;
            width:320px; height:320px; border-radius:50%;
            background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);
          "></div>
        </div>

        <div class="relative grid md:grid-cols-12 gap-0">
          <!-- Content -->
          <div class="md:col-span-8 p-8 md:p-12 lg:p-16">
            <!-- category + featured badge -->
            <div class="flex items-center gap-3 mb-6">
              <span
                class="text-xs font-bold uppercase tracking-[0.18em] px-2.5 py-1 rounded-sm"
                style={`background:rgba(255,255,255,0.12); color:${cat(featured.data.category).label}`}
              >
                {featured.data.category}
              </span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-saffron-400">
                ★ Featured
              </span>
            </div>

            <h2 class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight mb-4
                        group-hover:text-saffron-300 transition-colors duration-200">
              {featured.data.title}
            </h2>

            <p class="text-base md:text-lg leading-relaxed mb-8 max-w-2xl"
               style="color:rgba(255,255,255,0.72)">
              {featured.data.description}
            </p>

            <!-- Meta row -->
            <div class="flex flex-wrap items-center gap-4 md:gap-6">
              <div>
                <p class="text-sm font-semibold text-white">{featured.data.author}</p>
                {featured.data.authorRole && (
                  <p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.5)">{featured.data.authorRole}</p>
                )}
              </div>
              <span style="color:rgba(255,255,255,0.2)" class="hidden md:block">|</span>
              <p class="text-xs font-medium" style="color:rgba(255,255,255,0.5)">
                {formatDate(featured.data.date)}
              </p>
              <span style="color:rgba(255,255,255,0.2)" class="hidden md:block">|</span>
              <p class="text-xs font-medium" style="color:rgba(255,255,255,0.5)">
                {featured.data.readTime} min read
              </p>
            </div>

            <!-- CTA arrow -->
            <div class="mt-8 flex items-center gap-2 text-sm font-semibold text-saffron-400
                        group-hover:gap-4 transition-all duration-200">
              Read article
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6"
                      stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <!-- Right decorative panel — large number accent -->
          <div class="md:col-span-4 hidden md:flex items-center justify-center p-12" aria-hidden="true">
            <span class="font-serif font-bold select-none"
                  style="font-size:11rem; line-height:1; color:rgba(255,255,255,0.04); user-select:none">
              {featured.data.readTime}
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ── Article grid ──────────────────────────────────────────────── -->
  <section class="pb-16 md:pb-24" style="background:#F8F5EE">
    <div class="container-wide">

      <div class="flex items-center justify-between mb-8">
        <h2 class="font-serif text-xl font-semibold text-midnight-800">More Articles</h2>
        <span class="text-xs text-muted font-medium uppercase tracking-[0.16em]">
          {grid.length} articles
        </span>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {grid.map((post, i) => {
          const c = cat(post.data.category);
          return (
            <article
              class="group bg-white rounded-sm overflow-hidden border border-midnight-100
                     card-lift flex flex-col"
              data-reveal
              data-delay={String(Math.min((i % 3) * 100, 200))}
            >
              <!-- Colour header band -->
              <div
                class="relative flex items-end px-5 pt-5 pb-4"
                style={`background:${c.bg}; min-height:90px`}
              >
                <!-- category pill -->
                <span
                  class="absolute top-4 left-5 text-xs font-bold uppercase tracking-[0.15em] px-2 py-0.5 rounded-sm"
                  style={`background:rgba(255,255,255,0.12); color:${c.label}`}
                >
                  {post.data.category}
                </span>
                <!-- read time -->
                <span
                  class="absolute top-4 right-5 text-xs font-medium"
                  style="color:rgba(255,255,255,0.45)"
                >
                  {post.data.readTime} min
                </span>
              </div>

              <!-- Card body -->
              <div class="flex flex-col flex-1 p-5">
                <a href={`/blog/${post.slug}`} class="flex flex-col flex-1">
                  <h3
                    class="font-serif text-base md:text-lg font-semibold text-midnight-800
                           leading-snug mb-2 group-hover:text-saffron-600 transition-colors duration-150"
                  >
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-muted leading-relaxed line-clamp-3 flex-1">
                    {post.data.description}
                  </p>

                  <!-- Author + date footer -->
                  <div class="mt-4 pt-4 border-t border-midnight-50 flex items-center justify-between gap-2">
                    <div>
                      <p class="text-xs font-semibold text-midnight-700 leading-none">{post.data.author}</p>
                      {post.data.authorRole && (
                        <p class="text-xs text-muted mt-0.5 leading-none truncate max-w-[160px]">
                          {post.data.authorRole}
                        </p>
                      )}
                    </div>
                    <p class="text-xs text-muted shrink-0">{formatDate(post.data.date)}</p>
                  </div>
                </a>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── CTA strip ─────────────────────────────────────────────────── -->
  <section class="bg-midnight-800 py-14 md:py-16">
    <div class="container-wide text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-saffron-400 mb-3">
        GIMAC 17 · Alanya, Turkey · October 2026
      </p>
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">
        Present your research at GIMAC 17
      </h2>
      <p class="text-base max-w-xl mx-auto mb-8" style="color:rgba(255,255,255,0.65)">
        Submit your paper on Islamic marketing, halal economy, sustainable business,
        or Muslim consumer behaviour. Abstract deadline: 30 June 2026.
      </p>
      <a href="/submit" class="btn btn-primary">Submit a Paper</a>
    </div>
  </section>

</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
